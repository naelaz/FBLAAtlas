{
  "expo": {
    "name": "FBLA Atlas",
    "slug": "fbla-atlas",
    "scheme": "fblaatlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0A0A0A",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090A1A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FBLA Atlas uses your microphone so you can record and review presentation practice."
      }
    },
    "android": {
      "backgroundColor": "#0A0A0A",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      "expo-image",
      "expo-sharing",
      "expo-image-picker",
      "expo-web-browser",
      "expo-audio",
      "expo-asset"
    ]
  }
}
